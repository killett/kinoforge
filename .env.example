# Credential safety: tests redact these values automatically — see AGENTS.md
# "Credential safety in tests" + tests/providers/conftest_runpod.py.
# A `CredentialLeakError` at test time means the redactor needs a new pattern,
# not that your credential is wrong.
#
# kinoforge credentials — copy this file to .env and fill in values you need
# .env is in .gitignore; never commit your real .env file
# Recommended: chmod 600 .env
#
# Shell environment variables (export FAL_KEY=... in your shell or CI) ALWAYS
# win over .env values — .env only fills variables that are otherwise unset.

# fal.ai (hosted inference API)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=

# CivitAI (model source)
# Get from: https://civitai.com/user/account → API Keys
# Only required for gated / private models
CIVITAI_TOKEN=

# HuggingFace (model source)
# Get from: https://huggingface.co/settings/tokens (read-only token suffices)
# Only required for gated / private repos
HF_TOKEN=

# RunPod (compute provider)
# Get from: https://www.runpod.io/console/user/settings → API Keys
#
# RUNPOD_API_KEY is the main orchestration key (create/list/get/destroy pods).
# Treat as production credential; never embed in pod env.
RUNPOD_API_KEY=

# Scoped terminate-only key — embedded in the pod env so the in-pod self-
# terminator can self-destruct without holding the main key.
#
# RunPod does NOT currently offer a terminate-only scope (scoped-key UX is
# two-level: read/read+write GraphQL OR per-endpoint serverless). Until that
# changes, reuse the main key. python-dotenv expands ${RUNPOD_API_KEY} on
# load; bash `set -a; source .env; set +a` does too. When RunPod ships a
# terminate scope, paste that scoped key here verbatim instead.
RUNPOD_TERMINATE_KEY=${RUNPOD_API_KEY}

# GCP (SkyPilot compute provider + GCSArtifactStore)
#
# Path to a service-account key JSON file. Both google-cloud-storage and the
# skypilot `sky` SDK walk Google's default ADC chain and find this env var.
#
# To mint a key:
#   gcloud iam service-accounts create kinoforge-runner
#   PID=$(gcloud config get-value project)
#   SA=kinoforge-runner@${PID}.iam.gserviceaccount.com
#   for R in roles/compute.admin roles/iam.serviceAccountUser roles/storage.admin; do
#     gcloud projects add-iam-policy-binding "$PID" --member="serviceAccount:$SA" --role="$R"
#   done
#   gcloud iam service-accounts keys create .gcp/kinoforge-sa.json --iam-account="$SA"
#   chmod 600 .gcp/kinoforge-sa.json    # .gcp/ is in .gitignore
GOOGLE_APPLICATION_CREDENTIALS=

# Default GCS bucket for kinoforge artifacts (used when `store.kind: gcs` in YAML).
# Bucket must exist and the SA must have storage.admin on it.
KINOFORGE_GCS_BUCKET=
KINOFORGE_GCS_PREFIX=

# -----------------------------------------------------------------------------
# Hosted video-generation providers (Bearer-key API; pay-as-you-go credit card)
# -----------------------------------------------------------------------------
# All three use the same Hosted engine adapter — only the endpoint + key differ.
# Live smokes are gated by KINOFORGE_LIVE_TESTS=1 plus the provider key below.
# Pricing figures are rough as of 2026; verify against each provider's dashboard.

# Replicate (multi-model hosted inference — Wan, Mochi, LTX-Video, etc.)
# Get from: https://replicate.com/account/api-tokens
#
# Pay-as-you-go on credit card. Per-second pricing varies by model:
# ~$0.04-0.10 per 5-second clip on common video models.
# Env var name matches the official replicate Python SDK; the SDK's default
# chain picks it up automatically.
REPLICATE_API_TOKEN=

# RunwayML (Gen-3 Alpha, Gen-3 Turbo, Gen-4 — single-vendor hosted)
# Get from: https://dev.runwayml.com → API Keys
# NOTE: this is the developer portal (dev.runwayml.com), NOT the creative app
# at app.runwayml.com. The developer account is a separate signup.
#
# ~$0.05/sec on Gen-3 Turbo, ~$0.25/sec on Gen-4 hi-res; 5-second smoke ~$0.25.
# Env var name matches the official runwayml Python SDK convention.
RUNWAYML_API_SECRET=

# Luma AI Dream Machine (Ray 1.6, Ray 2 — single-vendor hosted)
# Get from: https://lumalabs.ai/dream-machine/api → API Keys
#
# ~$0.07-0.14/sec depending on tier; 5-second smoke ~$0.35-0.70.
# Env var name matches the official lumaai Python SDK convention.
LUMAAI_API_KEY=

# -----------------------------------------------------------------------------
# Cloud-native hosted video providers (no Bearer key — reuse existing creds)
# -----------------------------------------------------------------------------
# Vertex AI Veo and AWS Bedrock Nova Reel do NOT use API keys — they reuse
# the GCP service account (GOOGLE_APPLICATION_CREDENTIALS above) and the
# AWS SigV4 chain (boto3 walks AWS env / ~/.aws/credentials / IMDS).
#
# Operator setup for these — model-access enablement, region opt-in, and
# IAM/role grants — is documented in docs/CLOUD-CREDS.md, NOT here.
