# Credential safety: tests redact these values automatically — see AGENTS.md
# "Credential safety in tests" + tests/providers/conftest_runpod.py.
# A `CredentialLeakError` at test time means the redactor needs a new pattern,
# not that your credential is wrong.
#
# kinoforge credentials — copy this file to .env and fill in values you need
# .env is in .gitignore; never commit your real .env file
# Recommended: chmod 600 .env
#
# Shell environment variables (export FAL_KEY=... in your shell or CI) ALWAYS
# win over .env values — .env only fills variables that are otherwise unset.
#
# Convention: auth env vars use the upstream SDK's standard name (so the SDK's
# default credential chain finds them); kinoforge-specific config uses the
# KINOFORGE_* prefix.

# -----------------------------------------------------------------------------
# Model sources (registry read tokens)
# -----------------------------------------------------------------------------
# Only required for gated / private repos. Anonymous reads work without keys.

# CivitAI — community model registry
# Sign up:  https://civitai.com/login
# Get key:  https://civitai.com/user/account  (scroll to "API Keys")
CIVITAI_TOKEN=

# HuggingFace — model + dataset hub
# Sign up:  https://huggingface.co/join
# Get key:  https://huggingface.co/settings/tokens  (read-only token suffices)
HF_TOKEN=

# -----------------------------------------------------------------------------
# Compute providers
# -----------------------------------------------------------------------------

# RunPod — GPU pods (orchestration + in-pod self-terminate)
# Sign up:  https://www.runpod.io/console/signup
# Get key:  https://www.runpod.io/console/user/settings  → "API Keys"
#
# RUNPOD_API_KEY is the main orchestration key (create/list/get/destroy pods).
# Treat as production credential; never embed in pod env.
RUNPOD_API_KEY=

# Scoped terminate-only key — embedded in the pod env so the in-pod self-
# terminator can self-destruct without holding the main key.
#
# RunPod does NOT currently offer a terminate-only scope (scoped-key UX is
# two-level: read/read+write GraphQL OR per-endpoint serverless). Until that
# changes, reuse the main key. python-dotenv expands ${RUNPOD_API_KEY} on
# load; bash `set -a; source .env; set +a` does too. When RunPod ships a
# terminate scope, paste that scoped key here verbatim instead.
RUNPOD_TERMINATE_KEY=${RUNPOD_API_KEY}

# GCP — SkyPilot compute + ADC chain (also auths GCS below)
# Sign up:  https://cloud.google.com/free
# Console:  https://console.cloud.google.com/iam-admin/serviceaccounts
#
# Path to a service-account key JSON file. Both google-cloud-storage and the
# skypilot `sky` SDK walk Google's default ADC chain and find this env var.
#
# To mint a key:
#   gcloud iam service-accounts create kinoforge-runner
#   PID=$(gcloud config get-value project)
#   SA=kinoforge-runner@${PID}.iam.gserviceaccount.com
#   for R in roles/compute.admin roles/iam.serviceAccountUser roles/storage.admin; do
#     gcloud projects add-iam-policy-binding "$PID" --member="serviceAccount:$SA" --role="$R"
#   done
#   gcloud iam service-accounts keys create .gcp/kinoforge-sa.json --iam-account="$SA"
#   chmod 600 .gcp/kinoforge-sa.json    # .gcp/ is in .gitignore
GOOGLE_APPLICATION_CREDENTIALS=

# AWS — SkyPilot compute + boto3 default chain (also auths S3, Bedrock, KMS)
# Sign up:  https://portal.aws.amazon.com/billing/signup
# Console:  https://console.aws.amazon.com/iam/home  →  Users  →  create user
# Get key:  IAM user  →  "Security credentials"  →  "Create access key"
#                       →  "Command Line Interface (CLI)"  →  download CSV
#
# Project default region is us-west-2 — set AWS_DEFAULT_REGION accordingly.
# Two auth surfaces; either works (env vars below win over the file):
#   (a) env vars in this .env file  (CI-friendly, the SP-equivalent for AWS)
#   (b) shared credentials file at $AWS_SHARED_CREDENTIALS_FILE  (= .aws/credentials,
#       wired in pixi.toml [activation.env]; gitignored)
#
# To mint a headless IAM user (rough analogue of a GCP SA / Azure SP):
#   aws iam create-user --user-name kinoforge-runner
#   for P in AmazonEC2FullAccess AmazonS3FullAccess AmazonBedrockFullAccess; do
#     aws iam attach-user-policy --user-name kinoforge-runner \
#         --policy-arn arn:aws:iam::aws:policy/$P
#   done
#   aws iam create-access-key --user-name kinoforge-runner   # prints key + secret
# (Tighten policies for prod — these wide grants are bootstrap-only.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-2

# Azure — SkyPilot compute + azure-sdk default chain
# Sign up:  https://azure.microsoft.com/free
# Portal:   https://portal.azure.com
# Get key:  see service-principal mint command below
#
# Two auth modes:
#   (a) interactive  — `az login` once; token cached in $AZURE_CONFIG_DIR
#                      (workspace-local at .azure/, gitignored)
#   (b) service principal  — paste the four vars below (CI / headless)
#
# To mint a service principal (rough analogue of a GCP SA / AWS IAM user):
#   SUB=$(az account show --query id -o tsv)
#   az ad sp create-for-rbac --name kinoforge-runner --role Contributor \
#       --scopes /subscriptions/$SUB
# Output maps as: appId → AZURE_CLIENT_ID, password → AZURE_CLIENT_SECRET,
# tenant → AZURE_TENANT_ID. SUB → AZURE_SUBSCRIPTION_ID.
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Artifact storage (used when store.kind: <name> in YAML)
# -----------------------------------------------------------------------------
# Bucket / container must exist; credentials must have write access to it.

# GCS — Google Cloud Storage  (auths via GOOGLE_APPLICATION_CREDENTIALS above)
# Sign up:  https://cloud.google.com/free
# Console:  https://console.cloud.google.com/storage/browser
# SA needs storage.admin (or storage.objectAdmin) on the bucket.
KINOFORGE_GCS_BUCKET=
KINOFORGE_GCS_PREFIX=

# Cloudflare R2 — S3-compatible object store, zero egress fees
# Sign up:  https://dash.cloudflare.com/sign-up
# Get key:  https://dash.cloudflare.com  →  R2  →  "Manage R2 API Tokens"
#
# Account ID is shown on the R2 dashboard top-right. The S3 endpoint is
# https://<account_id>.r2.cloudflarestorage.com — boto3 hits this with the
# R2 access key pair below. The kinoforge R2 adapter constructs the endpoint
# from the account ID, so no separate endpoint var is needed.
KINOFORGE_R2_ACCOUNT_ID=
KINOFORGE_R2_ACCESS_KEY_ID=
KINOFORGE_R2_SECRET_ACCESS_KEY=
KINOFORGE_R2_BUCKET=
KINOFORGE_R2_PREFIX=

# Backblaze B2 — cheapest at-rest tier; S3-compatible API
# Sign up:  https://www.backblaze.com/sign-up/cloud-storage
# Get key:  https://secure.backblaze.com/app_keys.htm  ("Add a New Application Key")
#
# When you mint the application key, B2 prints its S3-compatible endpoint
# (e.g. https://s3.us-west-004.backblazeb2.com). Paste that endpoint verbatim
# below — it's region-specific and not derivable from the key ID alone.
# Env var names B2_APPLICATION_KEY_ID / B2_APPLICATION_KEY match the b2sdk
# Python library's default lookup.
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
KINOFORGE_B2_S3_ENDPOINT=
KINOFORGE_B2_BUCKET=
KINOFORGE_B2_PREFIX=

# Azure Blob Storage
# Sign up:  https://azure.microsoft.com/free
# Portal:   https://portal.azure.com  →  "Storage accounts"  →  create one
# Get key:  storage account  →  "Access keys" blade  →  "Show connection string"
#
# Connection string is the simplest auth form; azure-storage-blob's
# BlobServiceClient.from_connection_string() reads it whole. Env var name
# AZURE_STORAGE_CONNECTION_STRING matches the azure-sdk default lookup.
AZURE_STORAGE_CONNECTION_STRING=
KINOFORGE_AZURE_CONTAINER=
KINOFORGE_AZURE_PREFIX=

# -----------------------------------------------------------------------------
# Hosted video-generation providers (Bearer-key API; pay-as-you-go credit card)
# -----------------------------------------------------------------------------
# All use the same Hosted engine adapter — only the endpoint + key differ.
# Live smokes are gated by KINOFORGE_LIVE_TESTS=1 plus the provider key below.
# Pricing figures are rough as of 2026; verify against each provider's dashboard.

# fal.ai — multi-model hosted inference (Wan, LTX, Mochi, custom workflows)
# Sign up:  https://fal.ai/login
# Get key:  https://fal.ai/dashboard/keys
#
# ~$0.05-0.20 per 5-second clip depending on model. Env var name FAL_KEY
# matches the official fal-client Python SDK convention.
FAL_KEY=

# Replicate — multi-model hosted inference (Wan, Mochi, LTX-Video, etc.)
# Sign up:  https://replicate.com/signin
# Get key:  https://replicate.com/account/api-tokens
#
# Pay-as-you-go on credit card. Per-second pricing varies by model:
# ~$0.04-0.10 per 5-second clip on common video models. Env var name matches
# the official replicate Python SDK; the SDK's default chain picks it up.
REPLICATE_API_TOKEN=

# RunwayML — Gen-3 Alpha, Gen-3 Turbo, Gen-4 (single-vendor hosted)
# Sign up:  https://dev.runwayml.com  (developer portal — separate signup from
#                                      the creative app at app.runwayml.com)
# Get key:  https://dev.runwayml.com  →  "API Keys"
#
# ~$0.05/sec on Gen-3 Turbo, ~$0.25/sec on Gen-4 hi-res; 5-second smoke ~$0.25.
# Env var name RUNWAYML_API_SECRET matches the official runwayml Python SDK.
RUNWAYML_API_SECRET=

# Luma — UNI-1 image generation (keyframe pre-stage ONLY; video API retired)
# Sign up:  https://lumalabs.ai/api
# Get key:  https://platform.lumalabs.ai/keys   (key prefix: luma-api-...)
LUMAAI_API_KEY=

# -----------------------------------------------------------------------------
# Hosted video providers — Cloud-native (no Bearer key — reuse existing creds)
# -----------------------------------------------------------------------------
# Vertex AI Veo and AWS Bedrock Nova Reel do NOT use API keys — they reuse
# the GCP service account (GOOGLE_APPLICATION_CREDENTIALS above) and the
# AWS SigV4 chain (boto3 walks AWS env / ~/.aws/credentials / IMDS).
#
# Operator setup for these — model-access enablement, region opt-in, and
# IAM/role grants — is documented in docs/CLOUD-CREDS.md, NOT here.
