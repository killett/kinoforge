.claude-project-id

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Coverage + test caches
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build/runtime artefacts
.kinoforge/

# Editor + OS
.vscode/
.idea/
.DS_Store

# Local-only working scratch (issue drafts, handoff notes, etc.)
.tracking-issues/

# Secrets — never commit .env
.env

# Layer O — user-facing output directory (configurable per-run via --output-dir)
output/

# Superpowers brainstorming session state (PIDs, logs, transient HTML)
.superpowers/
