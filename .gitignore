.claude-project-id
.sandbox_settings.json

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Coverage + test caches
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build/runtime artefacts
.kinoforge/

# Editor + OS
.vscode/
.idea/
.DS_Store

# Local-only working scratch (issue drafts, handoff notes, etc.)
.tracking-issues/

# Secrets — never commit .env, GCP service-account keys, or AWS credentials
.env
.env.*
.gcp/
.aws/
# The .env.example template stays tracked
!.env.example

# Layer O — user-facing output directory (configurable per-run via --output-dir)
output/

# Superpowers brainstorming session state (PIDs, logs, transient HTML)
.superpowers/
*.log

# Live-smoke per-run record (git_sha, timings, artifact sha256) — local only
tests/engines/fixtures/comfyui/last_smoke.json

# Stray ops binaries downloaded into the workspace (runpodctl, etc.)
runpodctl
runpodctl.tar.gz
.gc-url.txt

# Stray local model weights (if a model/LoRA is ever pulled locally for tests)
*.safetensors
*.ckpt
*.pt
*.pth
*.gguf

# Stray credentials outside .gcp/ (backstop)
*.pem
*.key
*-sa.json
