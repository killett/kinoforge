{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeNovaReel",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel"
      ],
      "Resource": [
        "arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-reel-v1:1",
        "arn:aws:bedrock:us-east-1:<AWS_ACCOUNT>:async-invoke/*"
      ]
    },
    {
      "Sid": "AsyncInvokeNovaReel",
      "Effect": "Allow",
      "Action": [
        "bedrock:StartAsyncInvoke",
        "bedrock:GetAsyncInvoke"
      ],
      "Resource": [
        "arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-reel-v1:1",
        "arn:aws:bedrock:us-east-1:<AWS_ACCOUNT>:async-invoke/*"
      ]
    },
    {
      "Sid": "DiscoverFoundationModels",
      "Effect": "Allow",
      "Action": [
        "bedrock:ListFoundationModels"
      ],
      "Resource": "*"
    },
    {
      "Sid": "NovaReelOutputBucket",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:HeadObject"
      ],
      "Resource": [
        "arn:aws:s3:::kinoforge-nova-reel-output",
        "arn:aws:s3:::kinoforge-nova-reel-output/*"
      ]
    }
  ]
}
